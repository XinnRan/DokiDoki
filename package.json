{
  "name": "DokiDoki",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "main": "electron/main.js",
  "author": "XxinRan",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron\""
  },
  "build": {
    "appId": "com.heartrate.dokidoki",
    "productName": "DokiDoki",
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1"
  }
}
